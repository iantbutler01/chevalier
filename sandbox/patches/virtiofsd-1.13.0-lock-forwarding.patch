+#[cfg(test)]
+mod lock_interrupt_tests {
+    use super::*;
+    use std::sync::atomic::AtomicUsize;
+    use std::sync::Condvar;
+    use std::time::Instant;
+
+    struct EmptyDirectory;
+
+    impl DirectoryIterator for EmptyDirectory {
+        fn next(&mut self) -> Option<DirEntry<'_>> {
+            None
+        }
+    }
+
+    #[derive(Default)]
+    struct RetryLockFs {
+        allow_acquire: AtomicBool,
+        attempts: AtomicUsize,
+        acquired_owners: Mutex<Vec<u64>>,
+    }
+
+    impl FileSystem for RetryLockFs {
+        type Inode = u64;
+        type Handle = u64;
+        type DirIter = EmptyDirectory;
+
+        fn setlk(
+            &self,
+            _ctx: Context,
+            _inode: Self::Inode,
+            _handle: Self::Handle,
+            owner: u64,
+            _lock: FileLock,
+            _flags: u32,
+            sleep: bool,
+        ) -> io::Result<()> {
+            assert!(!sleep, "server retries must use nonblocking host calls");
+            self.attempts.fetch_add(1, Ordering::SeqCst);
+            if !self.allow_acquire.load(Ordering::SeqCst) {
+                return Err(io::Error::from_raw_os_error(libc::EAGAIN));
+            }
+            self.acquired_owners.lock().unwrap().push(owner);
+            Ok(())
+        }
+    }
+
+    fn wait_for(predicate: impl Fn() -> bool) {
+        let deadline = Instant::now() + Duration::from_secs(2);
+        while !predicate() {
+            assert!(Instant::now() < deadline, "condition timed out");
+            thread::sleep(Duration::from_millis(1));
+        }
+    }
+
+    fn test_lock() -> FileLock {
+        FileLock {
+            start: 0,
+            end: u64::MAX,
+            type_: libc::F_WRLCK as u32,
+            pid: 1,
+        }
+    }
+
+    #[test]
+    fn interrupt_cancels_only_its_target_without_a_late_lock() {
+        let server = Arc::new(Server::new(RetryLockFs::default()));
+        let first = {
+            let server = server.clone();
+            thread::spawn(move || {
+                server.setlkw_cancellable(
+                    101,
+                    Context::from(InHeader::default()),
+                    1,
+                    1,
+                    11,
+                    test_lock(),
+                    0,
+                )
+            })
+        };
+        let second = {
+            let server = server.clone();
+            thread::spawn(move || {
+                server.setlkw_cancellable(
+                    202,
+                    Context::from(InHeader::default()),
+                    1,
+                    2,
+                    22,
+                    test_lock(),
+                    0,
+                )
+            })
+        };
+
+        wait_for(|| server.fs.attempts.load(Ordering::SeqCst) >= 2);
+        assert!(server.interrupt_pending_lock_request(101).is_ok());
+        server.fs.allow_acquire.store(true, Ordering::SeqCst);
+
+        let first_error = first.join().unwrap().unwrap_err();
+        assert_eq!(first_error.raw_os_error(), Some(libc::EINTR));
+        second.join().unwrap().unwrap();
+        assert_eq!(*server.fs.acquired_owners.lock().unwrap(), vec![22]);
+        assert!(server.pending_lock_requests.lock().unwrap().is_empty());
+    }
+
+    #[derive(Default)]
+    struct SuccessGate {
+        entered: bool,
+        release: bool,
+    }
+
+    #[derive(Default)]
+    struct SerializedSuccessFs {
+        gate: Mutex<SuccessGate>,
+        gate_changed: Condvar,
+        acquired: AtomicUsize,
+    }
+
+    impl FileSystem for SerializedSuccessFs {
+        type Inode = u64;
+        type Handle = u64;
+        type DirIter = EmptyDirectory;
+
+        fn setlk(
+            &self,
+            _ctx: Context,
+            _inode: Self::Inode,
+            _handle: Self::Handle,
+            _owner: u64,
+            _lock: FileLock,
+            _flags: u32,
+            sleep: bool,
+        ) -> io::Result<()> {
+            assert!(!sleep);
+            let mut gate = self.gate.lock().unwrap();
+            gate.entered = true;
+            self.gate_changed.notify_all();
+            while !gate.release {
+                gate = self.gate_changed.wait(gate).unwrap();
+            }
+            self.acquired.fetch_add(1, Ordering::SeqCst);
+            Ok(())
+        }
+    }
+
+    #[test]
+    fn successful_acquisition_is_serialized_against_cancellation() {
+        let server = Arc::new(Server::new(SerializedSuccessFs::default()));
+        let worker = {
+            let server = server.clone();
+            thread::spawn(move || {
+                server.setlkw_cancellable(
+                    303,
+                    Context::from(InHeader::default()),
+                    1,
+                    1,
+                    33,
+                    test_lock(),
+                    0,
+                )
+            })
+        };
+
+        {
+            let mut gate = server.fs.gate.lock().unwrap();
+            while !gate.entered {
+                gate = server.fs.gate_changed.wait(gate).unwrap();
+            }
+        }
+        let cancel_started = Arc::new(AtomicBool::new(false));
+        let cancel = {
+            let server = server.clone();
+            let cancel_started = cancel_started.clone();
+            thread::spawn(move || {
+                cancel_started.store(true, Ordering::SeqCst);
+                server.cancel_pending_lock_request(303)
+            })
+        };
+        wait_for(|| cancel_started.load(Ordering::SeqCst));
+        thread::sleep(Duration::from_millis(20));
+        {
+            let mut gate = server.fs.gate.lock().unwrap();
+            gate.release = true;
+            server.fs.gate_changed.notify_all();
+        }
+
+        worker.join().unwrap().unwrap();
+        assert!(!cancel.join().unwrap());
+        assert_eq!(server.fs.acquired.load(Ordering::SeqCst), 1);
+        assert!(server.pending_lock_requests.lock().unwrap().is_empty());
+    }
+
+    #[test]
+    fn unknown_interrupt_is_retryable() {
+        let server = Server::new(RetryLockFs::default());
+        let error = server.interrupt_pending_lock_request(404).unwrap_err();
+        assert_eq!(error.raw_os_error(), Some(libc::EAGAIN));
+    }
+
+    #[test]
+    fn flush_cancels_matching_posix_wait_without_a_late_lock() {
+        let server = Arc::new(Server::new(RetryLockFs::default()));
+        let worker = {
+            let server = server.clone();
+            thread::spawn(move || {
+                server.setlkw_cancellable(
+                    505,
+                    Context::from(InHeader::default()),
+                    7,
+                    8,
+                    55,
+                    test_lock(),
+                    0,
+                )
+            })
+        };
+
+        wait_for(|| server.fs.attempts.load(Ordering::SeqCst) > 0);
+        assert_eq!(server.cancel_pending_posix_lock_requests(7, 54), 0);
+        assert_eq!(server.cancel_pending_posix_lock_requests(6, 55), 0);
+        assert_eq!(server.cancel_pending_posix_lock_requests(7, 55), 1);
+        server.fs.allow_acquire.store(true, Ordering::SeqCst);
+
+        let error = worker.join().unwrap().unwrap_err();
+        assert_eq!(error.raw_os_error(), Some(libc::EINTR));
+        assert!(server.fs.acquired_owners.lock().unwrap().is_empty());
+        assert!(server.pending_lock_requests.lock().unwrap().is_empty());
+    }
+
+    #[test]
+    fn release_cancels_matching_flock_wait_without_a_late_lock() {
+        let server = Arc::new(Server::new(RetryLockFs::default()));
+        let worker = {
+            let server = server.clone();
+            thread::spawn(move || {
+                server.setlkw_cancellable(
+                    606,
+                    Context::from(InHeader::default()),
+                    9,
+                    10,
+                    66,
+                    test_lock(),
+                    LK_FLOCK,
+                )
+            })
+        };
+
+        wait_for(|| server.fs.attempts.load(Ordering::SeqCst) > 0);
+        assert_eq!(server.cancel_pending_flock_lock_requests(9, 11), 0);
+        assert_eq!(server.cancel_pending_flock_lock_requests(8, 10), 0);
+        assert_eq!(server.cancel_pending_flock_lock_requests(9, 10), 1);
+        server.fs.allow_acquire.store(true, Ordering::SeqCst);
+
+        let error = worker.join().unwrap().unwrap_err();
+        assert_eq!(error.raw_os_error(), Some(libc::EINTR));
+        assert!(server.fs.acquired_owners.lock().unwrap().is_empty());
+        assert!(server.pending_lock_requests.lock().unwrap().is_empty());
+    }
+}
