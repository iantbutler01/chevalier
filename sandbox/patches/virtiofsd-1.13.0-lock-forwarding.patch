+#[cfg(test)]
+mod tests {
+    use super::{enable_seccomp, SeccompAction};
+
+    #[test]
+    fn clock_nanosleep_is_allowed_by_production_filter() {
+        let child = unsafe { libc::fork() };
+        assert!(child >= 0, "fork failed");
+
+        if child == 0 {
+            if enable_seccomp(SeccompAction::Kill, false).is_err() {
+                unsafe { libc::_exit(2) };
+            }
+            let request = libc::timespec {
+                tv_sec: 0,
+                tv_nsec: 1_000_000,
+            };
+            let result = unsafe {
+                libc::syscall(
+                    libc::SYS_clock_nanosleep,
+                    libc::CLOCK_MONOTONIC,
+                    0,
+                    &request,
+                    std::ptr::null_mut::<libc::timespec>(),
+                )
+            };
+            unsafe { libc::_exit(if result == 0 { 0 } else { 3 }) };
+        }
+
+        let mut status = 0;
+        assert_eq!(unsafe { libc::waitpid(child, &mut status, 0) }, child);
+        assert!(
+            libc::WIFEXITED(status),
+            "child was killed by seccomp: {}",
+            status
+        );
+        assert_eq!(libc::WEXITSTATUS(status), 0);
+    }
+}
